# Secrets
.env

# Claude Code local config
.claude/

# User-generated prompts (cached locally, not committed)
prompts/

# OS files
.DS_Store
Thumbs.db

# Python cache
__pycache__/

# Temp files
*.tmp

# Asset toolchain (mermaid-cli + mathjax-full are dev-only; generated SVGs are committed)
docs/assets/node_modules/
docs/assets/package-lock.json
docs/assets/package.json

# state/ is runtime + scratch. A concurrent session owns this dir.
# Precedent seed now lives inside the inference-engine plugin
# (plugins/inference-engine/state/artifacts.jsonl via backfill — see OP06).
# Nothing here ships.
state/

# Efficacy harness raw transcripts (verdict.json is the durable artifact).
# Redundant under the blanket state/ rule above, but kept explicit per the
# v0 efficacy-sandbox proposal (state/efficacy/<slug>/runs/).
state/efficacy/*/runs/
