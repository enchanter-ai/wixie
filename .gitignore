# Secrets
.env

# Claude Code local config
.claude/

# User-generated prompts (cached locally, not committed)
prompts/

# OS files
.DS_Store
Thumbs.db

# Python cache
__pycache__/

# Temp files
*.tmp

# Asset toolchain (mermaid-cli + mathjax-full are dev-only; generated SVGs are committed)
docs/assets/node_modules/
docs/assets/package-lock.json
docs/assets/package.json

# Guard against rogue agent scratch in the top-level state/ dir.
# state/precedent.jsonl is the only tracked artifact here; everything
# else is scratch (see OP06). Stray .py / .sh / simulation files never
# commit by accident, even if an agent forgets to clean up.
state/*.py
state/*.sh
state/sim_*
state/debug_*
state/*.tmp
state/scratch/
